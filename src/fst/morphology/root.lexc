LEXICON Root
!! The word forms in ApurinГЈ language start from the lexeme roots of basic
!! word classes, or optionally from prefixes:
!person_prefixes ; 
Nouns       ;
Verbs       ;
!   Adjectives  ;
   Adverbs  ;
   EXCEPTIONS ;
   Pronouns    ;
Propernouns	;
   Numerals    ;
   Prefixes    ;
   Punctuation ;
!   Symbols     ;
 PRONOUN-TYPES ;

LEXICON CS_
# ;

LEXICON ENDLEX
!! **@LEXNAME@**
ENDLEX2 ;

LEXICON ENDLEX2
!! **@LEXNAME@**
 @R.SpellRlx.ON@+Err/Spellrelax@C.SpellRlx@:@R.SpellRlx.ON@@C.SpellRlx@ ENDLEX3 ;
 @D.SpellRlx.ON@@C.SpellRlx@                                            ENDLEX3 ;

LEXICON ENDLEX3
# ;



